#!/usr/bin/env bash
# Usage: ensure-queue <owner/repo>
# Creates the Global Queue issue if it does not already exist.
set -euo pipefail

REPO="$1"

EXISTS=$(gh issue list --repo "$REPO" --state open --label "queue" \
  --json number,title --jq '.[] | select(.title == "Global Queue") | .number')

if [[ -z "$EXISTS" ]]; then
  gh issue create --repo "$REPO" \
    --title "Global Queue" \
    --label "queue" \
    --body-file ~/.agents/skills/setup/templates/queue.md
  echo "Global Queue created" >&2
else
  echo "Global Queue already present (#$EXISTS)" >&2
fi
